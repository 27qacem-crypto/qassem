{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@erp/shared-types": ["./packages/shared-types/src"],
      "@erp/shared-utils": ["./packages/shared-utils/src"],
      "@erp/database": ["./packages/database/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
